VITE_API_URL=http://localhost:4000/api
# Em desenvolvimento pode apagar VITE_API_URL: o Vite usa /api e /uploads com proxy (vite.config.js).
# As fotos das vantagens em dev passam sempre por esse proxy (/uploads), mesmo com VITE_API_URL definido.
# Se o backend não estiver em localhost:4000:
# VITE_DEV_PROXY_TARGET=http://127.0.0.1:4000
#
# Produção (Vercel): OBRIGATÓRIO — URL absoluta do backend (mesmo host onde corre Express e a pasta uploads/).
# Ex.: VITE_API_URL=https://teu-api.onrender.com/api
# Sem isto, o site tenta /uploads no domínio do Vercel e as imagens das vantagens falham.
# Se por algum motivo as fotos estiverem noutro domínio que a API:
# VITE_PUBLIC_FILES_ORIGIN=https://outro-dominio.com
